<?xml version="1.0"?>
<!--
/**
 * Panth Core — Outputs CSS variables from all registered module theme-config.json files.
 * Works on both Hyva and Luma themes.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template"
                   name="panth.core.css_variables"
                   template="Panth_Core::css-variables.phtml"
                   before="-">
                <arguments>
                    <argument name="theme_config" xsi:type="object">Panth\Core\ViewModel\ThemeConfig</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
