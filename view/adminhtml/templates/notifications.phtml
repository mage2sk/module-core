<?php foreach ($modalMessages as $modal): ?>
<?php
$mid             = (string) $modal->getData('message_id');
$mTitle          = (string) $modal->getData('title');
$mDesc           = (string) $modal->getData('description');
$mBodyHtml       = (string) $modal->getData('body_html');
$mImage          = (string) $modal->getData('image_url');
$mProxy          = (string) $modal->getData('proxy_url');
$mCta            = trim((string) $modal->getData('cta_label')) ?: __('View');
$mSecondaryUrl   = (string) $modal->getData('secondary_cta_url');
$mSecondaryLabel = (string) $modal->getData('secondary_cta_label');
?>
<div class="panth-modal-overlay" data-panth-popup data-message-id="<?= $escaper->escapeHtmlAttr($mid) ?>">
