/**
 * Copyright © Panth Infotech. All rights reserved.
 *
 * Renders Panth admin notifications in two display modes:
 *   - top-of-page banner for messages flagged pin_to_top
 *   - login popup modal for messages flagged display_as_popup
 *
 * The same modal HTML is also reused when an admin clicks "Read more"
 * on the banner — a single source of truth for the rich body, CTAs,
 * and image. Both modes share self-contained CSS + JS (no jQuery, no
 * RequireJS dependency) so they work on any Magento backend theme.
 *
 * Brand palette matches kishansavaliya.com: deep orange primary
 * (#F26B22) with a slightly warmer hover, paired with a charcoal
 * secondary on a near-white background. Severity colours stay distinct
 * but muted toward the same warm family so red/yellow/blue notices
 * don't clash with the orange CTAs.
 *
 * @var \Panth\Core\Block\Adminhtml\Notifications $block
 * @var \Magento\Framework\Escaper $escaper
 */

$banners = $block->getBannerMessages();
$popups  = $block->getPopupMessages();

if (empty($banners) && empty($popups)) {
    return;
}

$markShownUrl = $block->getMarkShownUrl();
$dismissUrl   = $block->getDismissUrl();
$formKey      = $block->getFormKey();

// Build a unique set of messages we need a modal for: every popup message
// and every banner message (because the banner's "Read more" opens it).
$modalMessages = [];
$seen = [];
foreach (array_merge($popups, $banners) as $m) {
    $id = (string) $m->getData('message_id');
    if ($id === '' || isset($seen[$id])) {
        continue;
    }
    $seen[$id] = true;
    $modalMessages[] = $m;
}

// Auto-open IDs are messages with display_as_popup=1 that this admin
// hasn't dismissed and hasn't seen MAX_POPUP_SHOWS times yet — already
// pre-filtered server-side by AdminNotificationProvider::getPopupMessages.
$autoOpenId = !empty($popups) ? (string) $popups[0]->getData('message_id') : '';
?>
