/**
 * Copyright © Panth Infotech. All rights reserved.
 *
 * Renders Panth admin notifications in two display modes that mimic
 * Magento's native backend chrome:
 *   - top-of-page notice bar (matches `.message-system` styling)
 *   - centred login popup modal (matches `.modal-popup` styling)
 *
 * Inherits Magento admin's font stack (Open Sans → Helvetica → Arial)
 * via cascade — no font-family override here. Buttons use the
 * `.action-primary` / `.action-secondary` palette so they sit visually
 * alongside Magento's own admin buttons.
 *
 * @var \Panth\Core\Block\Adminhtml\Notifications $block
 * @var \Magento\Framework\Escaper $escaper
 */

$banners = $block->getBannerMessages();
$popups  = $block->getPopupMessages();

if (empty($banners) && empty($popups)) {
    return;
}

$markShownUrl = $block->getMarkShownUrl();
$dismissUrl   = $block->getDismissUrl();
$formKey      = $block->getFormKey();

// Build the unique set of messages we need a modal for: every popup
// AND every banner (because the banner's "Read more" reuses the same
// modal). Dedupe on message_id so a message flagged for both modes
// only renders one modal.
$modalMessages = [];
$seen = [];
foreach (array_merge($popups, $banners) as $m) {
    $id = (string) $m->getData('message_id');
    if ($id === '' || isset($seen[$id])) {
        continue;
    }
    $seen[$id] = true;
    $modalMessages[] = $m;
}

$autoOpenId = !empty($popups) ? (string) $popups[0]->getData('message_id') : '';
?>
