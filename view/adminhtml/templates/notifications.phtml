<?php if (!empty($banners)): ?>
<?php foreach ($banners as $banner): ?>
    <?php
    $messageId = (string) $banner->getData('message_id');
    $severity  = (string) $banner->getData('severity');
    $title     = (string) $banner->getData('title');
