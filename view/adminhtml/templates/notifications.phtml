<script>
(function(){
    'use strict';
    var formKey = <?= /* @noEscape */ json_encode($formKey) ?>;
    var markShownUrl = <?= /* @noEscape */ json_encode($markShownUrl) ?>;
    var dismissUrl = <?= /* @noEscape */ json_encode($dismissUrl) ?>;
    var autoOpenId = <?= /* @noEscape */ json_encode($autoOpenId) ?>;

    function postState(url, messageId) {
        try {
            var data = new FormData();
            data.append('form_key', formKey);
            data.append('message_id', messageId);
            // sendBeacon survives navigation away (e.g. CTA click in same tab)
            if (navigator.sendBeacon) {
                navigator.sendBeacon(url, data);
                return;
            }
            var xhr = new XMLHttpRequest();
            xhr.open('POST', url, true);
            xhr.send(data);
        } catch (e) {
            // Best-effort: never break the admin flow over an analytics ping.
        }
    }

    function findPopupForMessage(messageId) {
        return document.querySelector('[data-panth-popup][data-message-id="' + cssEscape(messageId) + '"]');
    }

    // CSS.escape isn't on every admin browser; tiny safe fallback.
    function cssEscape(value) {
        if (window.CSS && CSS.escape) return CSS.escape(value);
        return String(value).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
    }

    function openPopup(messageId, recordShown) {
        var popup = findPopupForMessage(messageId);
        if (!popup) return;
        popup.classList.add('active');
        if (recordShown) {
            postState(markShownUrl, messageId);
        }
    }

    function closePopup(popup) {
        popup.classList.remove('active');
    }

    function dismissMessage(messageId) {
        postState(dismissUrl, messageId);
        // Remove the banner if present
        var banner = document.querySelector('[data-panth-banner][data-message-id="' + cssEscape(messageId) + '"]');
        if (banner) banner.style.display = 'none';
        // Close + hide every modal for this message
        document.querySelectorAll('[data-panth-popup][data-message-id="' + cssEscape(messageId) + '"]').forEach(function(p){
            p.classList.remove('active');
        });
    }

    // --- Banner controls ---
    document.querySelectorAll('[data-panth-banner]').forEach(function(banner){
        var messageId = banner.getAttribute('data-message-id');
        // Banner X = dismiss
        var dismissBtn = banner.querySelector('[data-panth-banner-dismiss]');
        if (dismissBtn) {
            dismissBtn.addEventListener('click', function(){
                dismissMessage(messageId);
            });
        }
        // "Read more" opens the popup
        var readMore = banner.querySelector('[data-panth-readmore]');
        if (readMore) {
            readMore.addEventListener('click', function(){
                openPopup(messageId, false);
            });
        }
    });

    // --- Modal controls ---
    document.querySelectorAll('[data-panth-popup]').forEach(function(popup){
        var messageId = popup.getAttribute('data-message-id');
        // Close button (× and outline-only "Close")
        popup.querySelectorAll('[data-panth-close]').forEach(function(btn){
            btn.addEventListener('click', function(){ closePopup(popup); });
        });
        // Mark as read = permanent dismiss + close
        var markRead = popup.querySelector('[data-panth-mark-read]');
        if (markRead) {
            markRead.addEventListener('click', function(){
                dismissMessage(messageId);
            });
        }
        // CTA / secondary opens in new tab AND counts as a dismiss
        var cta = popup.querySelector('[data-panth-cta]');
        if (cta) {
            cta.addEventListener('click', function(){
                postState(dismissUrl, messageId);
                closePopup(popup);
            });
        }
        var secondary = popup.querySelector('[data-panth-secondary]');
        if (secondary) {
            secondary.addEventListener('click', function(){
                postState(dismissUrl, messageId);
                closePopup(popup);
            });
        }
        // Click outside the modal also closes (without permanent dismiss)
        popup.addEventListener('click', function(e){
            if (e.target === popup) {
                closePopup(popup);
            }
        });
    });

    // Auto-open on load for messages flagged display_as_popup
    if (autoOpenId) {
        openPopup(autoOpenId, true);
    }

    // ESC closes any open modal
    document.addEventListener('keydown', function(e){
        if (e.key !== 'Escape') return;
        document.querySelectorAll('[data-panth-popup].active').forEach(function(p){
            closePopup(p);
        });
    });
})();
</script>
