<?php if (!empty($popups)): ?>
<?php
// Render the FIRST eligible popup. Multiple popups stacking on top of each
// other on first login is bad UX — subsequent popups appear on the next
// admin page-load until each is shown its 3 times.
$popup = $popups[0];
$popupMessageId = (string) $popup->getData('message_id');
$popupSeverity  = (string) $popup->getData('severity');
$popupTitle     = (string) $popup->getData('title');
$popupDesc      = (string) $popup->getData('description');
$popupBodyHtml  = (string) $popup->getData('body_html');
$popupImage     = (string) $popup->getData('image_url');
$popupProxy     = (string) $popup->getData('proxy_url');
$popupCta       = trim((string) $popup->getData('cta_label')) ?: __('Read more');
$popupSecondaryUrl   = (string) $popup->getData('secondary_cta_url');
$popupSecondaryLabel = (string) $popup->getData('secondary_cta_label');
?>
<div class="panth-notif-modal-overlay" data-panth-popup data-message-id="<?= $escaper->escapeHtmlAttr($popupMessageId) ?>">
    <div class="panth-notif-modal" role="dialog" aria-modal="true" aria-labelledby="panth-notif-popup-title">
        <div class="panth-notif-modal__header">
            <span class="panth-notif-modal__sev sev-<?= $escaper->escapeHtmlAttr($popupSeverity) ?>" aria-hidden="true"></span>
            <h2 id="panth-notif-popup-title" class="panth-notif-modal__title"><?= $escaper->escapeHtml($popupTitle) ?></h2>
            <button type="button" class="panth-notif-modal__close" data-panth-dismiss aria-label="<?= $escaper->escapeHtmlAttr(__('Close')) ?>">×</button>
        </div>
        <?php if ($popupImage): ?>
            <img class="panth-notif-modal__image" src="<?= $escaper->escapeUrl($popupImage) ?>" alt=""/>
        <?php endif; ?>
        <div class="panth-notif-modal__body">
            <?php if ($popupBodyHtml !== ''): ?>
                <?= /* @noEscape */ $popupBodyHtml ?>
            <?php else: ?>
                <p><?= $escaper->escapeHtml($popupDesc) ?></p>
            <?php endif; ?>
        </div>
        <div class="panth-notif-modal__footer">
            <?php if ($popupSecondaryUrl !== '' && $popupSecondaryLabel !== ''): ?>
                <a class="panth-notif-modal__btn panth-notif-modal__btn--secondary"
                   href="<?= $escaper->escapeUrl($popupSecondaryUrl) ?>"
                   rel="noopener"
                   data-panth-secondary><?= $escaper->escapeHtml($popupSecondaryLabel) ?></a>
            <?php endif; ?>
            <?php if ($popupProxy): ?>
                <a class="panth-notif-modal__btn panth-notif-modal__btn--primary"
                   href="<?= $escaper->escapeUrl($popupProxy) ?><?= str_contains($popupProxy, '?') ? '&' : '?' ?>src=popup"
                   rel="noopener"
                   data-panth-cta><?= $escaper->escapeHtml($popupCta) ?></a>
            <?php else: ?>
                <button type="button" class="panth-notif-modal__btn panth-notif-modal__btn--primary" data-panth-dismiss><?= $escaper->escapeHtml(__('Got it')) ?></button>
            <?php endif; ?>
        </div>
    </div>
</div>
<?php endif; ?>

<script>
(function(){
    'use strict';
    var formKey = <?= /* @noEscape */ json_encode($formKey) ?>;
    var markShownUrl = <?= /* @noEscape */ json_encode($markShownUrl) ?>;
    var dismissUrl = <?= /* @noEscape */ json_encode($dismissUrl) ?>;

    function postState(url, messageId) {
        try {
            var data = new FormData();
            data.append('form_key', formKey);
            data.append('message_id', messageId);
            // sendBeacon if available — survives navigation away (e.g. CTA click)
            if (navigator.sendBeacon) {
                navigator.sendBeacon(url, data);
                return;
            }
            var xhr = new XMLHttpRequest();
            xhr.open('POST', url, true);
            xhr.send(data);
        } catch (e) {
            // Best-effort. If recording fails the popup will be shown one extra
            // time at most — never break the admin flow over it.
        }
    }

    // --- Top banner dismissals ---
    document.querySelectorAll('[data-panth-banner]').forEach(function(banner){
        banner.querySelector('[data-panth-dismiss]').addEventListener('click', function(){
            postState(dismissUrl, banner.getAttribute('data-message-id'));
            banner.style.display = 'none';
        });
    });

    // --- Popup ---
    var popup = document.querySelector('[data-panth-popup]');
    if (popup) {
        var messageId = popup.getAttribute('data-message-id');
        // Show it
        popup.classList.add('active');
        // Tell the server we showed it (counts toward MAX_POPUP_SHOWS)
        postState(markShownUrl, messageId);

        function dismissPopup() {
            postState(dismissUrl, messageId);
            popup.classList.remove('active');
        }
        popup.querySelectorAll('[data-panth-dismiss]').forEach(function(btn){
            btn.addEventListener('click', dismissPopup);
        });
        // CTA / secondary clicks count as dismiss too — admin took action
        var cta = popup.querySelector('[data-panth-cta]');
        if (cta) {
            cta.addEventListener('click', function(){
                postState(dismissUrl, messageId);
                // don't preventDefault — let the navigation happen via the click proxy
            });
        }
        var secondary = popup.querySelector('[data-panth-secondary]');
        if (secondary) {
            secondary.addEventListener('click', function(){
                postState(dismissUrl, messageId);
            });
        }
        // Click outside the modal also dismisses
        popup.addEventListener('click', function(e){
            if (e.target === popup) {
                dismissPopup();
            }
        });
        // ESC closes
        document.addEventListener('keydown', function(e){
            if (e.key === 'Escape' && popup.classList.contains('active')) {
                dismissPopup();
            }
        });
    }
})();
</script>
