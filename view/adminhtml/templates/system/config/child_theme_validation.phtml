<?php
/**
 * Child Theme Validation Template
 *
 * @var \Panth\Core\Block\Adminhtml\System\Config\ChildThemeValidation $block
 */
$results = $block->getValidationResults();
$themeInfo = $results['theme_info'] ?? [];
$checks = $results['checks'] ?? [];
$validateUrl = $block->getValidateUrl();
$rebuildUrl = $block->getRebuildUrl();
?>
